# ─────────────────────────────────────────────────────────────────────────────
# Staxiq Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI (Anthropic / Claude) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Network ──────────────────────────────────────────────────────────────────
STACKS_NETWORK=mainnet
VITE_STACKS_NETWORK=mainnet

# ── Stacks RPC ───────────────────────────────────────────────────────────────
STACKS_API_BASE=https://api.hiro.so

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3002
VITE_API_BASE=http://localhost:3002

# CORS origins for production (comma-separated).
# Leave empty in .env.example — set only in production deployment.
# CORS_ORIGINS=https://staxiq.vercel.app

# Rate limiting (optional overrides)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100

# ── Contracts ────────────────────────────────────────────────────────────────
# VITE_CONTRACT_ADDRESS=SP...
# VITE_CONTRACT_NAME=staxiq-user-profile

# ── Protocol APIs ────────────────────────────────────────────────────────────
ZEST_API_BASE=https://api.zestprotocol.com
GRANITE_API_BASE=https://api.granite.world

# ── Price oracle ─────────────────────────────────────────────────────────────
COINGECKO_BASE=https://api.coingecko.com/api/v3

# ── Optional Redis cache (Upstash) ────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ── Production Deployment ─────────────────────────────────────────────────────
# Step 1: Deploy backend (server.js + server/) to Railway, Render, or Fly.io
#   - Railway: push to GitHub, connect repo, it auto-detects Dockerfile
#   - Render:  use render.yaml or connect repo
#   - Fly.io:  fly launch && fly deploy
#
# Required env vars on backend host:
#   NODE_ENV=production
#   PORT=10000 (or let host assign)
#   STACKS_NETWORK=mainnet
#   CORS_ORIGINS=https://your-vercel-app.vercel.app
#   ANTHROPIC_API_KEY=sk-ant-... (if using AI features)
#
# Step 2: Set VITE_API_BASE in Vercel to your backend's public URL
#   Example: https://staxiq-api.onrender.com
# ─────────────────────────────────────────────────────────────────────────────
